# Database
DATABASE_URL="postgresql://user:password@localhost:5432/gym_saga_admin"

# Authentication
JWT_SECRET="your_super_secret_jwt_key_min_32_chars"
JWT_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# Admin API
ADMIN_API_URL="http://localhost:3001"
ADMIN_API_SECRET="super_secret_inter_service_key"

# Frontend Admin
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Redis (para BullMQ)
REDIS_URL="redis://localhost:6379"

# Build Worker
BUILD_WORKER_CONCURRENCY="2"
BUILD_WORKER_QUEUE_NAME="app-builds"

# Storage S3 Compatible
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="gym-saga-builds"
S3_REGION="us-east-1"

# Security
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://localhost:3002,https://admin.gym-saga.com"
RATE_LIMIT_WINDOW="15m"
RATE_LIMIT_MAX_REQUESTS="100"

# Logging
LOG_LEVEL="info"
NODE_ENV="development"

# MFA Secret (para TOTP)
MFA_WINDOW="1"

# Email (opcional para notificaciones)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="noreply@gym-saga.com"
